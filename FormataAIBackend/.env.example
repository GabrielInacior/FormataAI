# ─── Banco de Dados ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/formataAI?schema=public"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET="TROQUE_ESTA_CHAVE_EM_PRODUCAO"
JWT_EXPIRES_IN="7d"

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── AWS S3 ──────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="formataai-arquivos"
S3_DIAS_EXPIRACAO=10

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
